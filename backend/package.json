{
  "name": "barberia-backend",
  "version": "1.0.0",
  "description": "Backend para Sistema de Gestión de Barberías",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "ts-node src/index.ts",
    "db:setup": "prisma db push && prisma db seed",
    "db:seed": "prisma db seed",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "barberia",
    "citas",
    "reservas"
  ],
  "author": "Tu Nombre",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^4.16.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "joi": "^18.2.3",
    "jsonwebtoken": "~9.0.2",
    "pg": "^8.11.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "~2.4.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.20",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.9.0",
    "prisma": "^4.16.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
