<main class="min-h-screen bg-[#020B18] text-white">
  <section class="flex min-h-screen items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <a
        href="/"
        class="mb-8 inline-flex text-sm font-semibold text-[#1E6DFF] transition hover:text-[#ffc928]"
      >
        Volver al inicio
      </a>

      <div class="rounded-lg border border-[#0D47A1] bg-[#061B33] p-6 shadow-2xl shadow-black/30 sm:p-8">
        <div class="text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-[#ffc928]">
            Bienvenido
          </p>
          <h1 class="mt-3 text-3xl font-black text-white">
            Iniciar sesión
          </h1>
          <p class="mt-3 text-sm leading-6 text-[#C7D2E1]">
            Ingresa con tu cuenta para gestionar tus citas.
          </p>
        </div>

        <form id="login-form" class="mt-8 grid gap-5" method="post">
          <label class="grid gap-2 text-left">
            <span class="text-sm font-semibold text-white">Correo electrónico</span>
            <input
              type="email"
              name="email"
              placeholder="correo@ejemplo.com"
              required
              class="rounded-lg border border-[#0D47A1] bg-[#020B18] px-4 py-3 text-white outline-none transition placeholder:text-[#8798B3] focus:border-[#1E6DFF] focus:ring-2 focus:ring-[#1E6DFF]/20"
            />
          </label>

          <label class="grid gap-2 text-left">
            <span class="text-sm font-semibold text-white">Contraseña</span>
            <input
              type="password"
              name="password"
              placeholder="Ingresa tu contraseña"
              required
              class="rounded-lg border border-[#0D47A1] bg-[#020B18] px-4 py-3 text-white outline-none transition placeholder:text-[#8798B3] focus:border-[#1E6DFF] focus:ring-2 focus:ring-[#1E6DFF]/20"
            />
          </label>

          <button
            id="login-button"
            type="submit"
            class="rounded-lg bg-[#1261D8] px-6 py-4 text-base font-bold text-white transition hover:-translate-y-0.5 hover:bg-[#1E6DFF] hover:shadow-md focus:outline-none focus:ring-2 focus:ring-[#1E6DFF] focus:ring-offset-2 focus:ring-offset-[#061B33]"
          >
            <span id="login-button-text">Entrar</span>
          </button>
        </form>

        <p id="login-message" class="mt-4 hidden rounded-lg px-4 py-3 text-sm font-semibold"></p>

        <p class="mt-6 text-center text-sm text-[#C7D2E1]">
          ¿No tienes cuenta?
          <a href="/registro" class="font-bold text-[#1E6DFF] transition hover:text-[#ffc928]">
            Regístrate
          </a>
        </p>
      </div>
    </div>
  </section>
</main>

<script>
  const API_URL = 'http://localhost:3001/api';
  const form = document.querySelector<HTMLFormElement>('#login-form');
  const message = document.querySelector<HTMLParagraphElement>('#login-message');
  const button = document.querySelector<HTMLButtonElement>('#login-button');
  const buttonText = document.querySelector<HTMLSpanElement>('#login-button-text');

  const showMessage = (text: string, type: 'success' | 'error') => {
    if (!message) return;

    message.textContent = text;
    message.className =
      type === 'success'
        ? 'mt-4 rounded-lg border border-green-500/50 bg-green-500/10 px-4 py-3 text-sm font-semibold text-green-300'
        : 'mt-4 rounded-lg border border-red-500/50 bg-red-500/10 px-4 py-3 text-sm font-semibold text-red-300';
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const email = String(formData.get('email') || '').trim();
    const password = String(formData.get('password') || '');

    button?.setAttribute('disabled', 'true');
    if (buttonText) buttonText.textContent = 'Ingresando...';

    try {
      const response = await fetch(`${API_URL}/auth/login`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email, password }),
      });

      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data.message || data.error || 'No se pudo iniciar sesión.');
      }

      const token = data.token || data.accessToken || data.jwt;
      const user = data.usuario || data.user;

      if (token) localStorage.setItem('token', token);
      if (user) localStorage.setItem('user', JSON.stringify(user));

      showMessage('Sesión iniciada correctamente.', 'success');
      window.setTimeout(() => {
        const requestedRedirect = new URLSearchParams(window.location.search).get('redirect');
        const safeRedirect = requestedRedirect?.startsWith('/') && !requestedRedirect.startsWith('//')
          ? requestedRedirect
          : '/home';
        window.location.href = safeRedirect;
      }, 800);
    } catch (error) {
      const text = error instanceof Error ? error.message : 'Error al iniciar sesión.';
      showMessage(text, 'error');
    } finally {
      button?.removeAttribute('disabled');
      if (buttonText) buttonText.textContent = 'Entrar';
    }
  });
</script>

