<main class="min-h-screen bg-white text-zinc-900">
  <section class="flex min-h-screen items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <a
        href="/"
        class="mb-8 inline-flex text-sm font-semibold text-violet-700 transition hover:text-violet-900"
      >
        Volver al inicio
      </a>

      <div class="rounded-xl border border-zinc-200 bg-white p-6 shadow-lg shadow-zinc-200/70 sm:p-8">
        <div class="text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-violet-700">
            Bienvenido
          </p>
          <h1 class="mt-3 text-3xl font-black text-zinc-950">
            Iniciar sesion
          </h1>
          <p class="mt-3 text-sm leading-6 text-zinc-600">
            Ingresa con tu cuenta para gestionar tus citas.
          </p>
        </div>

        <form id="login-form" class="mt-8 grid gap-5" method="post">
          <label class="grid gap-2 text-left">
            <span class="text-sm font-semibold text-zinc-800">Correo electronico</span>
            <input
              type="email"
              name="email"
              placeholder="correo@ejemplo.com"
              required
              class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-zinc-900 outline-none transition placeholder:text-zinc-400 focus:border-violet-600 focus:ring-2 focus:ring-violet-100"
            />
          </label>

          <label class="grid gap-2 text-left">
            <span class="text-sm font-semibold text-zinc-800">Contrasena</span>
            <input
              type="password"
              name="password"
              placeholder="Ingresa tu contrasena"
              required
              class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-zinc-900 outline-none transition placeholder:text-zinc-400 focus:border-violet-600 focus:ring-2 focus:ring-violet-100"
            />
          </label>

          <button
            id="login-button"
            type="submit"
            class="rounded-lg bg-violet-700 px-6 py-4 text-base font-bold text-white transition hover:-translate-y-0.5 hover:bg-violet-800 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2"
          >
            <span id="login-button-text">Entrar</span>
          </button>
        </form>

        <p id="login-message" class="mt-4 hidden rounded-lg px-4 py-3 text-sm font-semibold"></p>

        <p class="mt-6 text-center text-sm text-zinc-600">
          No tienes cuenta?
          <a href="/registro" class="font-bold text-violet-700 transition hover:text-violet-900">
            Registrate
          </a>
        </p>
      </div>
    </div>
  </section>
</main>

<script>
  const API_URL = 'http://localhost:3001/api';
  const form = document.querySelector<HTMLFormElement>('#login-form');
  const message = document.querySelector<HTMLParagraphElement>('#login-message');
  const button = document.querySelector<HTMLButtonElement>('#login-button');
  const buttonText = document.querySelector<HTMLSpanElement>('#login-button-text');

  const showMessage = (text: string, type: 'success' | 'error') => {
    if (!message) return;

    message.textContent = text;
    message.className =
      type === 'success'
        ? 'mt-4 rounded-lg bg-green-50 px-4 py-3 text-sm font-semibold text-green-700'
        : 'mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm font-semibold text-red-700';
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const email = String(formData.get('email') || '').trim();
    const password = String(formData.get('password') || '');

    button?.setAttribute('disabled', 'true');
    if (buttonText) buttonText.textContent = 'Ingresando...';

    try {
      const response = await fetch(`${API_URL}/auth/login`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email, password }),
      });

      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data.message || data.error || 'No se pudo iniciar sesion.');
      }

      const token = data.token || data.accessToken || data.jwt;
      const user = data.usuario || data.user;

      if (token) localStorage.setItem('token', token);
      if (user) localStorage.setItem('user', JSON.stringify(user));

      showMessage('Sesion iniciada correctamente.', 'success');
      window.setTimeout(() => {
        const requestedRedirect = new URLSearchParams(window.location.search).get('redirect');
        const safeRedirect = requestedRedirect?.startsWith('/') && !requestedRedirect.startsWith('//')
          ? requestedRedirect
          : '/home';
        window.location.href = safeRedirect;
      }, 800);
    } catch (error) {
      const text = error instanceof Error ? error.message : 'Error al iniciar sesion.';
      showMessage(text, 'error');
    } finally {
      button?.removeAttribute('disabled');
      if (buttonText) buttonText.textContent = 'Entrar';
    }
  });
</script>
