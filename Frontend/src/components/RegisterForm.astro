<main class="min-h-screen bg-white text-zinc-900">
  <section class="flex min-h-screen items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <a
        href="/"
        class="mb-8 inline-flex text-sm font-semibold text-violet-700 transition hover:text-violet-900"
      >
        Volver al inicio
      </a>

      <div class="rounded-xl border border-zinc-200 bg-white p-6 shadow-lg shadow-zinc-200/70 sm:p-8">
        <div class="text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-violet-700">
            Crear cuenta
          </p>
          <h1 class="mt-3 text-3xl font-black text-zinc-950">
            Registrarse
          </h1>
          <p class="mt-3 text-sm leading-6 text-zinc-600">
            Crea tu cuenta para reservar horas en barberías de Concepción.
          </p>
        </div>

        <form id="register-form" class="mt-8 grid gap-5" method="post">
          <label class="grid gap-2 text-left">
            <span class="text-sm font-semibold text-zinc-800">Nombre completo</span>
            <input
              type="text"
              name="nombre"
              placeholder="Tu nombre"
              required
              class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-zinc-900 outline-none transition placeholder:text-zinc-400 focus:border-violet-600 focus:ring-2 focus:ring-violet-100"
            />
          </label>

          <label class="grid gap-2 text-left">
            <span class="text-sm font-semibold text-zinc-800">Correo electrónico</span>
            <input
              type="email"
              name="email"
              placeholder="correo@ejemplo.com"
              required
              class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-zinc-900 outline-none transition placeholder:text-zinc-400 focus:border-violet-600 focus:ring-2 focus:ring-violet-100"
            />
          </label>

          <label class="grid gap-2 text-left">
            <span class="text-sm font-semibold text-zinc-800">Contraseña</span>
            <input
              type="password"
              name="password"
              placeholder="Crea una contraseña"
              required
              class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-zinc-900 outline-none transition placeholder:text-zinc-400 focus:border-violet-600 focus:ring-2 focus:ring-violet-100"
            />
          </label>

          <label class="grid gap-2 text-left">
            <span class="text-sm font-semibold text-zinc-800">Teléfono</span>
            <input
              type="tel"
              name="telefono"
              placeholder="Ej: 555123456"
              required
              class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-zinc-900 outline-none transition placeholder:text-zinc-400 focus:border-violet-600 focus:ring-2 focus:ring-violet-100"
            />
          </label>

          <fieldset class="grid gap-3 text-left">
            <legend class="text-sm font-semibold text-zinc-800">Tipo de cuenta</legend>
            <div class="grid gap-3 sm:grid-cols-2">
              <label class="cursor-pointer rounded-lg border border-zinc-300 bg-white p-4 transition hover:border-violet-500 has-[:checked]:border-violet-700 has-[:checked]:bg-violet-50 has-[:checked]:ring-2 has-[:checked]:ring-violet-100">
                <input
                  class="sr-only"
                  type="radio"
                  name="rol"
                  value="cliente"
                  checked
                />
                <span class="block text-sm font-black text-zinc-950">Cliente</span>
                <span class="mt-1 block text-xs font-semibold leading-5 text-zinc-500">Reservar horas</span>
              </label>

              <label class="cursor-pointer rounded-lg border border-zinc-300 bg-white p-4 transition hover:border-violet-500 has-[:checked]:border-violet-700 has-[:checked]:bg-violet-50 has-[:checked]:ring-2 has-[:checked]:ring-violet-100">
                <input
                  class="sr-only"
                  type="radio"
                  name="rol"
                  value="barbero"
                />
                <span class="block text-sm font-black text-zinc-950">Barbero</span>
                <span class="mt-1 block text-xs font-semibold leading-5 text-zinc-500">Requiere aprobación del administrador</span>
              </label>
            </div>
            <p id="barber-approval-note" class="hidden rounded-lg bg-amber-50 px-4 py-3 text-xs font-semibold leading-5 text-amber-700">
              Las cuentas de barbero quedan pendientes hasta que un administrador las apruebe.
            </p>
          </fieldset>

          <button
            id="register-button"
            type="submit"
            class="rounded-lg bg-zinc-950 px-6 py-4 text-base font-bold text-white transition hover:-translate-y-0.5 hover:bg-zinc-800 hover:shadow-md focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2"
          >
            <span id="register-button-text">Crear cuenta</span>
          </button>
        </form>

        <p id="register-message" class="mt-4 hidden rounded-lg px-4 py-3 text-sm font-semibold"></p>

        <p class="mt-6 text-center text-sm text-zinc-600">
          ¿Ya tienes cuenta?
          <a href="/login" class="font-bold text-violet-700 transition hover:text-violet-900">
            Inicia sesión
          </a>
        </p>
      </div>
    </div>
  </section>
</main>

<script>
  const API_URL = 'http://localhost:3001/api';
  const form = document.querySelector<HTMLFormElement>('#register-form');
  const message = document.querySelector<HTMLParagraphElement>('#register-message');
  const button = document.querySelector<HTMLButtonElement>('#register-button');
  const buttonText = document.querySelector<HTMLSpanElement>('#register-button-text');
  const barberApprovalNote = document.querySelector<HTMLParagraphElement>('#barber-approval-note');
  const roleInputs = document.querySelectorAll<HTMLInputElement>('input[name="rol"]');

  const showMessage = (text: string, type: 'success' | 'error') => {
    if (!message) return;

    message.textContent = text;
    message.className =
      type === 'success'
        ? 'mt-4 rounded-lg bg-green-50 px-4 py-3 text-sm font-semibold text-green-700'
        : 'mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm font-semibold text-red-700';
  };

  const updateApprovalNote = () => {
    const selectedRole = form?.querySelector<HTMLInputElement>('input[name="rol"]:checked')?.value;
    barberApprovalNote?.classList.toggle('hidden', selectedRole !== 'barbero');
  };

  roleInputs.forEach((input) => input.addEventListener('change', updateApprovalNote));
  updateApprovalNote();

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const payload = {
      nombre: String(formData.get('nombre') || '').trim(),
      email: String(formData.get('email') || '').trim(),
      password: String(formData.get('password') || ''),
      telefono: String(formData.get('telefono') || '').trim(),
      rol: String(formData.get('rol') || 'cliente'),
    };

    button?.setAttribute('disabled', 'true');
    if (buttonText) buttonText.textContent = 'Creando cuenta...';

    try {
      const response = await fetch(`${API_URL}/usuarios`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json().catch(() => ({}));

      if (!response.ok) {
        throw new Error(data.message || data.error || 'No se pudo crear la cuenta.');
      }

      const successMessage =
        payload.rol === 'barbero'
          ? 'Solicitud enviada correctamente. Un administrador debe aprobar tu cuenta antes de iniciar sesión.'
          : 'Cuenta creada correctamente. Ahora puedes iniciar sesión.';

      showMessage(successMessage, 'success');
      form.reset();
      updateApprovalNote();

      window.setTimeout(() => {
        window.location.href = '/login';
      }, payload.rol === 'barbero' ? 2200 : 1000);
    } catch (error) {
      const text = error instanceof Error ? error.message : 'Error al crear la cuenta.';
      showMessage(text, 'error');
    } finally {
      button?.removeAttribute('disabled');
      if (buttonText) buttonText.textContent = 'Crear cuenta';
    }
  });
</script>
