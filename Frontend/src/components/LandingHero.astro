---
import logoConce from '../assets/logotesis.png';
import paginaInicio from '../assets/paginainicio.png';
---

<main
  class="min-h-screen bg-white bg-cover bg-center bg-no-repeat text-white"
  style={`background-image: url(${paginaInicio.src});`}
>
  <section class="flex min-h-screen items-center justify-center px-6 py-12">
    <div class="mx-auto w-full max-w-3xl text-center">
      <img
        src={logoConce.src}
        alt="Conce Barber Club"
        class="mx-auto mb-6 h-auto w-36"
      />

      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.22em] text-[#ffc928]">
        BARBERÍAS EN CONCEPCIÓN
      </p>

      <h1 class="text-4xl font-black leading-tight tracking-normal text-white sm:text-5xl">
        Gestiona tus citas y encuentra <span class="text-[#ffc928]">barberos</span> <span class="text-[#39b54a]">cerca de ti</span>
      </h1>

      <p class="mx-auto mt-5 max-w-2xl text-base leading-7 text-white sm:text-lg">
        Reserva horas, revisa disponibilidad y conecta con profesionales de barbería en Concepción de forma simple y rápida.
      </p>

      <div class="mx-auto mt-10 grid w-full max-w-md gap-4">
        <a
          href="/login"
          class="rounded-lg bg-[#1261D8] px-6 py-4 text-base font-bold text-white shadow-sm transition hover:-translate-y-0.5 hover:bg-[#1E6DFF] hover:shadow-md focus:outline-none focus:ring-2 focus:ring-[#1E6DFF] focus:ring-offset-2"
        >
          Iniciar sesión
        </a>

        <a
          href="/registro"
          class="rounded-lg bg-[#ffc928] px-6 py-4 text-base font-bold text-[#061a45] shadow-sm transition hover:-translate-y-0.5 hover:bg-[#ffd94d] hover:shadow-md focus:outline-none focus:ring-2 focus:ring-[#ffc928] focus:ring-offset-2"
        >
          Registrarse
        </a>

        <a
          href="/home"
          class="rounded-lg bg-zinc-950 px-6 py-4 text-base font-bold text-white transition hover:-translate-y-0.5 hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-zinc-900 focus:ring-offset-2"
        >
          Continuar como invitado
        </a>
      </div>
    </div>
  </section>
</main>
