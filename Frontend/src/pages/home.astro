---
import Layout from '../layouts/Layout.astro';
import FeaturedBarbers from '../components/FeaturedBarbers.astro';
import HomeHeader from '../components/HomeHeader.astro';
import HomeHero from '../components/HomeHero.astro';
import barberiaFoto from '../assets/barberia.jpg';
import conceChile from '../assets/Conce-Chile.jpg';
import logoConce from '../assets/logotesis.png';
import {
  CalendarCheck,
  CalendarDays,
  CheckCircle2,
  Instagram,
  Mail,
  MapPin,
  Search,
  UserRoundPlus,
} from 'lucide-astro';
import '../styles/home.css';
---

<Layout title="Inicio - Barberías Concepción">
  <div class="home-root">
    <section class="home-hero-shell" id="inicio" style={`--conce-bg: url(${conceChile.src});`}>
      <HomeHeader logoSrc={logoConce.src} />
      <HomeHero />
    </section>

    <main class="home-main">
      <FeaturedBarbers />

      <section class="how-section" id="como-funciona">
        <div class="section-heading">
          <h2>¿Cómo funciona?</h2>
        </div>

        <div class="how-grid">
          <article class="how-card">
            <span class="step-number">1</span>
            <Search class="how-icon" size={44} aria-hidden="true" />
            <div>
              <h3>Encuentra tu barbero</h3>
              <p>Busca y compara barberos según tu estilo, ubicación y servicios.</p>
            </div>
          </article>

          <article class="how-card">
            <span class="step-number">2</span>
            <CalendarDays class="how-icon" size={44} aria-hidden="true" />
            <div>
              <h3>Elige fecha y hora</h3>
              <p>Consulta la disponibilidad en tiempo real y elige el horario que prefieras.</p>
            </div>
          </article>

          <article class="how-card">
            <span class="step-number">3</span>
            <CheckCircle2 class="how-icon" size={44} aria-hidden="true" />
            <div>
              <h3>Reserva tu cita</h3>
              <p>Confirma tu reserva en segundos y recibe la confirmación al instante.</p>
            </div>
          </article>
        </div>
      </section>

      <section class="barber-invite">
        <div class="barber-invite-media" style={`--invite-image: url(${barberiaFoto.src});`}></div>
        <div>
          <h2>¿Eres barbero?</h2>
          <p>Haz crecer tu negocio con Conce Barber Club. Crea tu perfil profesional, administra tu agenda y recibe reservas todos los días.</p>
        </div>
        <div class="barber-invite-action">
          <a class="btn btn-primary" href="/registro">
            <UserRoundPlus class="button-icon" size={21} aria-hidden="true" />
            Crear perfil profesional
          </a>
          <span>Únete a nuestra comunidad de barberos.</span>
        </div>
      </section>

      <section class="home-cta">
        <CalendarDays class="cta-lucide-icon" size={34} aria-hidden="true" />
        <div>
          <h2>¿Listo para tu próximo corte?</h2>
          <p>Reserva ahora y vive la experiencia Conce Barber Club.</p>
        </div>
        <a class="btn btn-primary" href="/booking">
          <CalendarDays class="button-icon" size={21} aria-hidden="true" />
          Reservar ahora
        </a>
      </section>
    </main>

    <footer class="home-footer" id="contacto">
      <div class="home-footer-inner">
        <a class="footer-brand" href="/home" aria-label="Conce Barber Club">
          <img src={logoConce.src} alt="Conce Barber Club" />
        </a>

        <div>
          <h2>Navegación</h2>
          <a href="#inicio">Inicio</a>
          <a href="/barberos">Barberos</a>
          <a href="#contacto">Sobre nosotros</a>
          <a href="#como-funciona">Cómo funciona</a>
        </div>

        <div>
          <h2>Síguenos</h2>
          <div class="social-links">
            <a href="#" aria-label="Instagram"><Instagram size={18} aria-hidden="true" /></a>
            <a href="#" aria-label="Reservas"><CalendarCheck size={18} aria-hidden="true" /></a>
          </div>
        </div>

        <div>
          <h2>Contacto</h2>
          <p><Mail size={16} aria-hidden="true" /> franciscoflorescares@gmail.com</p>
          <p><MapPin size={16} aria-hidden="true" /> Concepción, Chile</p>
        </div>
      </div>

      <p class="footer-copy">© 2026 Conce Barber Club.</p>
    </footer>
  </div>
</Layout>
