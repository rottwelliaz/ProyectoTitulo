---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Barberos pendientes - Admin">
  <main class="min-h-screen bg-[#020B18] px-6 py-10 text-white">
    <section class="mx-auto max-w-5xl">
      <a href="/home" class="inline-flex text-sm font-bold text-[#1E6DFF] transition hover:text-white">
        ← Volver al inicio
      </a>

      <div class="mt-8 rounded-2xl border border-[#0D47A1] bg-[#061B33] p-6 shadow-2xl shadow-black/30">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-black uppercase tracking-[0.18em] text-[#F2C230]">Admin</p>
            <h1 class="mt-2 text-3xl font-black">Barberos pendientes</h1>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-[#C7D2E1]">
              Revisa las solicitudes de cuentas de barbero y apruébalas para que puedan iniciar sesión y crear su perfil profesional.
            </p>
          </div>
          <button
            id="refresh-pending-barbers"
            type="button"
            class="rounded-xl border border-[#1261D8] px-5 py-3 text-sm font-black text-white transition hover:border-[#1E6DFF] hover:bg-[#1261D8]"
          >
            Actualizar
          </button>
        </div>

        <p id="admin-message" class="mt-5 hidden rounded-xl px-4 py-3 text-sm font-bold"></p>
        <div id="pending-barbers-list" class="mt-6 grid gap-4"></div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const API_URL = 'http://localhost:3001/api';
  const token = localStorage.getItem('token');
  const storedUser = localStorage.getItem('user');
  const list = document.querySelector<HTMLDivElement>('#pending-barbers-list');
  const message = document.querySelector<HTMLParagraphElement>('#admin-message');
  const refreshButton = document.querySelector<HTMLButtonElement>('#refresh-pending-barbers');

  const showMessage = (text: string, type: 'success' | 'error') => {
    if (!message) return;
    message.textContent = text;
    message.className =
      type === 'success'
        ? 'mt-5 rounded-xl border border-green-500/50 bg-green-500/10 px-4 py-3 text-sm font-bold text-green-300'
        : 'mt-5 rounded-xl border border-red-500/50 bg-red-500/10 px-4 py-3 text-sm font-bold text-red-300';
  };

  const escapeHtml = (value: unknown) =>
    String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');

  const getUser = () => {
    try {
      return storedUser ? JSON.parse(storedUser) : null;
    } catch {
      return null;
    }
  };

  const renderEmpty = (text: string) => {
    if (!list) return;
    list.innerHTML = `<div class="rounded-xl border border-[#0D47A1] bg-[#020B18] p-5 text-[#C7D2E1]">${escapeHtml(text)}</div>`;
  };

  const loadPendingBarbers = async () => {
    if (!token) {
      window.location.href = '/login?redirect=/admin-barberos';
      return;
    }

    const user = getUser();
    if (user?.rol !== 'admin') {
      renderEmpty('No tienes permisos para ver esta página.');
      showMessage('Solo un usuario administrador puede aprobar barberos.', 'error');
      return;
    }

    if (list) list.innerHTML = '<div class="rounded-xl border border-[#0D47A1] bg-[#020B18] p-5 text-[#C7D2E1]">Cargando solicitudes...</div>';

    try {
      const response = await fetch(`${API_URL}/usuarios/barberos/pendientes`, {
        headers: {
          Authorization: `Bearer ${token}`,
        },
      });

      const data = await response.json().catch(() => []);
      if (!response.ok) {
        throw new Error(data.message || 'No se pudieron cargar los barberos pendientes.');
      }

      if (!Array.isArray(data) || data.length === 0) {
        renderEmpty('No hay barberos pendientes por aprobar.');
        return;
      }

      if (!list) return;
      list.innerHTML = data
        .map((barber) => {
          const date = barber.fecha_creacion ? new Date(barber.fecha_creacion).toLocaleDateString('es-CL') : '-';
          return `
            <article class="grid gap-4 rounded-xl border border-[#0D47A1] bg-[#020B18] p-5 sm:grid-cols-[1fr_auto] sm:items-center">
              <div>
                <h2 class="text-xl font-black">${escapeHtml(barber.nombre)}</h2>
                <p class="mt-1 text-sm text-[#C7D2E1]">${escapeHtml(barber.email)}</p>
                <p class="mt-1 text-sm text-[#C7D2E1]">Teléfono: ${escapeHtml(barber.telefono || 'No registrado')}</p>
                <p class="mt-2 text-xs font-bold uppercase tracking-[0.16em] text-[#F2C230]">Solicitado: ${escapeHtml(date)}</p>
              </div>
              <button
                type="button"
                class="approve-barber rounded-xl bg-[#1261D8] px-5 py-3 text-sm font-black text-white transition hover:bg-[#1E6DFF]"
                data-id="${escapeHtml(barber.id)}"
              >
                Aprobar barbero
              </button>
            </article>
          `;
        })
        .join('');
    } catch (error) {
      const text = error instanceof Error ? error.message : 'Error al cargar solicitudes.';
      renderEmpty(text);
      showMessage(text, 'error');
    }
  };

  list?.addEventListener('click', async (event) => {
    const button = (event.target as HTMLElement).closest<HTMLButtonElement>('.approve-barber');
    if (!button || !token) return;

    button.disabled = true;
    button.textContent = 'Aprobando...';

    try {
      const response = await fetch(`${API_URL}/usuarios/${button.dataset.id}/aprobar-barbero`, {
        method: 'PATCH',
        headers: {
          Authorization: `Bearer ${token}`,
        },
      });

      const data = await response.json().catch(() => ({}));
      if (!response.ok) {
        throw new Error(data.message || 'No se pudo aprobar el barbero.');
      }

      showMessage('Barbero aprobado correctamente.', 'success');
      await loadPendingBarbers();
    } catch (error) {
      const text = error instanceof Error ? error.message : 'Error al aprobar barbero.';
      showMessage(text, 'error');
      button.disabled = false;
      button.textContent = 'Aprobar barbero';
    }
  });

  refreshButton?.addEventListener('click', loadPendingBarbers);
  loadPendingBarbers();
</script>
